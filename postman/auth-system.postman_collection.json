{
    "info": {
        "name": "Auth System API",
        "description": "Complete API reference for the Laravel authentication system.\n\nBase URL: {{base_url}}/api\n\nAll authenticated endpoints require:\n- Header: Authorization: Bearer {{token}}\n- Header: Accept: application/json",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "base_url", "value": "http://auth.test", "type": "string" },
        { "key": "token", "value": "", "type": "string" }
    ],
    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "X-Device-Fingerprint", "value": "sha256hashhere", "description": "Optional device fingerprint" }
                        ],
                        "body": { "mode": "raw", "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
                        "header": [ { "key": "Accept", "value": "application/json" } ],
                        "body": { "mode": "raw", "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Forgot Password",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/forgot-password", "host": ["{{base_url}}"], "path": ["api","auth","forgot-password"] },
                        "header": [ { "key": "Accept", "value": "application/json" } ],
                        "body": { "mode": "raw", "raw": "{\n    \"email\": \"john@example.com\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Reset Password",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/reset-password", "host": ["{{base_url}}"], "path": ["api","auth","reset-password"] },
                        "header": [ { "key": "Accept", "value": "application/json" } ],
                        "body": { "mode": "raw", "raw": "{\n    \"token\": \"reset-token-from-email\",\n    \"email\": \"john@example.com\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Resend Verification",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/resend-verification", "host": ["{{base_url}}"], "path": ["api","auth","resend-verification"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Session",
            "item": [
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api","auth","logout"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                },
                {
                    "name": "Get User",
                    "request": {
                        "method": "GET",
                        "url": { "raw": "{{base_url}}/api/user", "host": ["{{base_url}}"], "path": ["api","user"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                },
                {
                    "name": "Verify Email",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/verify-email", "host": ["{{base_url}}"], "path": ["api","auth","verify-email"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Two-Factor Authentication",
            "item": [
                {
                    "name": "Enable 2FA",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/two-factor/enable", "host": ["{{base_url}}"], "path": ["api","auth","two-factor","enable"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                },
                {
                    "name": "Confirm 2FA",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/two-factor/confirm", "host": ["{{base_url}}"], "path": ["api","auth","two-factor","confirm"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": { "mode": "raw", "raw": "{\n    \"code\": \"123456\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Disable 2FA",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/two-factor/disable", "host": ["{{base_url}}"], "path": ["api","auth","two-factor","disable"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                },
                {
                    "name": "Verify OTP",
                    "request": {
                        "method": "POST",
                        "url": { "raw": "{{base_url}}/api/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api","auth","verify-otp"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": { "mode": "raw", "raw": "{\n    \"code\": \"123456\"\n}", "options": { "raw": { "language": "json" } } }
                    }
                },
                {
                    "name": "Get Recovery Codes",
                    "request": {
                        "method": "GET",
                        "url": { "raw": "{{base_url}}/api/auth/two-factor/recovery-codes", "host": ["{{base_url}}"], "path": ["api","auth","two-factor","recovery-codes"] },
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ]
                    }
                }
            ]
        }
    ]
}
